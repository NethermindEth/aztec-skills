{
  "name": "install-aztec-skills",
  "version": "4.1.0-rc.1-v0.3.0",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "description": "Interactive installer for Aztec skills in Codex and Claude.",
  "type": "module",
  "bin": {
    "install-aztec-skills": "bin/install-aztec-skills.mjs"
  },
  "files": [
    "bin",
    "src",
    "aztec-contracts",
    "aztec-deployment",
    "aztec-js",
    "aztec-accounts",
    "aztec-pxe",
    "aztec-wallet-sdk",
    "aztec-testing",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm pack --dry-run",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ci": "biome format --write . && biome check . && tsc -p tsconfig.json --noEmit && bun run test",
    "test": "bash scripts/smoke-installer.sh && bash scripts/check-packaged-contents.sh"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.2",
    "typescript": "^5.9.3"
  }
}
